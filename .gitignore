data/processed/**
!data/processed/
!data/processed/**/
!data/processed/**/*.csv

data/labelled/**
!data/labelled/
!data/labelled/*.csv

# ─── Folder placeholders and docs ────────────────────────────────────────────────
!data/**/README.md
!data/**/README.txt
!data/**/.gitkeep
!data/README.md

# ─── Banks (archive/scratch) — never push ─────────────────────────────────────
banks/
josh_processed_data
