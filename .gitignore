# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# ─── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ─── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
._*
Thumbs.db
desktop.ini

# ─── Large raw data — do NOT push to GitHub ───────────────────────────────────
# Entire raw data tree is excluded. Transfer via USB/cloud storage.
# Folder structure and README files ARE tracked so teammates know what to place here.
data/raw/

# ─── Processed outputs — large, regenerable ───────────────────────────────────
data/processed/
data/rinex/
data/labelled/

# But always track README files and folder placeholders inside data/
!data/
!data/raw/
!data/raw/**/
!data/**/README.md
!data/**/README.txt
!data/**/.gitkeep
!data/README.md

# ─── Banks (archive/scratch) — never push ─────────────────────────────────────
banks/

# ─── Media (photos) — too large for Git ──────────────────────────────────────
media/field_photos/*
media/team_photos/*
# Keep the placeholder so folder structure is tracked
!media/field_photos/.gitkeep
!media/team_photos/.gitkeep

# ─── Results — charts/PNGs are tracked; model weights are not ─────────────────
# Charts, figures, and analysis PNGs → pushed to GitHub (small, useful to share)
# Trained model weights → NOT pushed (large, regenerable from training data)
results/models/*.pkl
results/models/*.h5
results/models/*.pt
results/models/*.pth
results/models/*.joblib
results/models/*.bin

# ─── Route planning charts (regenerable PNGs) ─────────────────────────────────
route_planning/analysis/**/*.png

# ─── VS Code ──────────────────────────────────────────────────────────────────
.vscode/

# ─── Always track these regardless of above rules ────────────────────────────
!**/.gitkeep
!docs/dataset_references/*.pdf